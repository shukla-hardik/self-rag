ENV=local
LOG_LEVEL=DEBUG

# Database (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=self_rag
DB_USER=postgres
DB_PASSWORD=postgres
DB_ECHO=false

# CORS (comma-separated origins)
CORS_ALLOWED_URL=http://localhost:3000,http://localhost:8000

#Gemini LLM config
GEMINI_API_KEY=""
GEMINI_MODEL=""
GEMINI_EMBEDDING_MODEL=""

# Context evaluation thresholds (chunk relevance scores, 0.0–1.0)
CONTEXT_EVAL_HIGHER_THR=0.7
CONTEXT_EVAL_LOWER_THR=0.3

# AWS (S3 + SQS, backed by localstack for local dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET_NAME=self-rag-documents
SQS_QUEUE_NAME=self-rag-ingest

# Internal service auth
INTERNAL_TOKEN=changeme